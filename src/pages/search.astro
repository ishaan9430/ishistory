---
import Base from '../layouts/Base.astro';
import Cosmos from '../components/Cosmos.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Search — ishistory"
  description="Search all episodes across every ishistory series."
>

<Cosmos />
<Nav />

<section class="search-hero">
  <p class="search-label">Full-text Search</p>
  <h1 class="search-title">Search All Episodes</h1>
  <div class="search-wrap">
    <input
      type="search"
      id="searchInput"
      class="search-input"
      placeholder="Search by title, topic, or keyword…"
      autocomplete="off"
      autofocus
    />
    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
  </div>
</section>

<div class="results-section">
  <p class="result-count" id="resultCount"></p>
  <div class="results-grid" id="resultsContainer"></div>
  <div class="empty-state" id="emptyState">
    <div class="empty-icon">✦</div>
    <p>Start typing to search across all episodes</p>
  </div>
</div>

<Footer />

<style>
.search-hero {
  padding: 9rem 2.5rem 3.5rem;
  position: relative; z-index: 1;
  max-width: 860px;
}
.search-hero::after {
  content: '';
  position: absolute;
  top: 68px; left: 2.5rem; right: 2.5rem; height: 1px;
  background: linear-gradient(to right, #8b3a1a, rgba(200,151,58,0.4), transparent 65%);
}
.search-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.62rem; letter-spacing: 0.28em;
  text-transform: uppercase; color: #c4622a;
  margin-bottom: 0.75rem; opacity: 0.85;
}
.search-title {
  font-family: 'Libre Baskerville', serif;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 700; font-style: italic;
  color: #f0e8d8; margin-bottom: 2rem; line-height: 1.1;
}
.search-wrap {
  position: relative; max-width: 620px;
}
.search-icon {
  position: absolute; left: 1.1rem; top: 50%;
  transform: translateY(-50%);
  width: 18px; height: 18px; color: #564b3c;
  pointer-events: none;
}
.search-input {
  width: 100%;
  background: rgba(20,18,24,0.9);
  border: 1px solid rgba(160,144,120,0.2);
  border-radius: 4px;
  color: #e4d9c4;
  font-family: 'Crimson Pro', serif; font-size: 1.1rem;
  padding: 1rem 1.2rem 1rem 3rem;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.search-input:focus {
  border-color: rgba(200,151,58,0.45);
  box-shadow: 0 0 0 3px rgba(200,151,58,0.08);
}
.search-input::placeholder { color: #564b3c; font-style: italic; }

/* ── RESULTS ── */
.results-section {
  padding: 0 2.5rem 8rem;
  position: relative; z-index: 1;
  max-width: 860px;
}
.result-count {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.6rem; letter-spacing: 0.15em;
  text-transform: uppercase; color: #564b3c;
  margin-bottom: 1.5rem; min-height: 1.2em;
}
.results-grid {
  display: flex; flex-direction: column; gap: 1rem;
}

/* ── CARD ── */
.result-card {
  display: block; text-decoration: none; color: inherit;
  background: rgba(20,18,24,0.8);
  border: 1px solid rgba(160,144,120,0.1);
  border-radius: 8px;
  padding: 1.6rem 1.8rem;
  transition: background 0.2s, border-color 0.2s, transform 0.2s;
  position: relative; overflow: hidden;
}
.result-card::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; border-radius: 8px 0 0 8px;
  background: linear-gradient(to bottom, #8b3a1a, #c8973a);
  transform: scaleY(0); transform-origin: bottom;
  transition: transform 0.28s ease;
}
.result-card:hover {
  background: rgba(28,24,32,0.95);
  border-color: rgba(200,151,58,0.22);
  transform: translateY(-2px);
}
.result-card:hover::before { transform: scaleY(1); }

.result-card-top {
  display: flex; align-items: center;
  justify-content: space-between; gap: 1rem;
  margin-bottom: 0.6rem;
}
.result-series {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.55rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: #c4622a; opacity: 0.85;
}
.result-tag {
  font-family: 'DM Mono', monospace;
  font-size: 0.55rem; letter-spacing: 0.1em;
  text-transform: uppercase; color: #564b3c;
  background: rgba(200,151,58,0.07);
  padding: 0.2rem 0.6rem; border-radius: 3px;
  flex-shrink: 0;
}
.result-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.15rem; font-weight: 700;
  color: #f0e8d8; margin-bottom: 0.5rem;
  line-height: 1.3; transition: color 0.2s;
}
.result-card:hover .result-title { color: #d97a42; }
.result-desc {
  font-family: 'Crimson Pro', serif;
  font-size: 0.97rem; line-height: 1.65; color: #9a8f7e;
}
.result-arrow {
  position: absolute; right: 1.5rem; top: 50%;
  transform: translateY(-50%);
  font-size: 0.85rem; color: rgba(196,98,42,0.2);
  transition: color 0.2s, transform 0.2s;
}
.result-card:hover .result-arrow {
  color: #c4622a;
  transform: translateY(-50%) translateX(3px);
}

/* ── EMPTY STATE ── */
.empty-state {
  text-align: center; padding: 5rem 0;
  color: #564b3c;
}
.empty-state.hidden { display: none; }
.empty-icon {
  font-size: 1.5rem; margin-bottom: 1rem;
  color: rgba(200,151,58,0.25);
}
.empty-state p {
  font-family: 'Crimson Pro', serif;
  font-size: 1.05rem; font-style: italic; color: #564b3c;
}

/* ── NO RESULTS ── */
.no-results {
  text-align: center; padding: 4rem 0;
}
.no-results p {
  font-family: 'Crimson Pro', serif;
  font-size: 1.1rem; font-style: italic; color: #564b3c;
}
.no-results span {
  display: block; margin-top: 0.5rem;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.6rem; letter-spacing: 0.15em;
  text-transform: uppercase; color: #3a3028;
}

@media (max-width: 768px) {
  .search-hero { padding: 7.5rem 1.5rem 3rem; }
  .search-hero::after { left: 1.5rem; right: 1.5rem; }
  .results-section { padding: 0 1.5rem 5rem; }
  .result-card { padding: 1.3rem 1.4rem; }
  .result-arrow { display: none; }
}
</style>

<script>
const SERIES_LABELS: Record<string, string> = {
  'ai-history': 'History of AI',
  'robotics': 'History of Robotics',
  'internet-history': 'History of the Internet'
};

let searchIndex: any[] = [];
let debounceTimer: ReturnType<typeof setTimeout>;

// Load index
fetch('/search-index.json')
  .then(r => r.json())
  .then(data => {
    searchIndex = data;
    const q = new URLSearchParams(window.location.search).get('q');
    if (q) {
      const input = document.getElementById('searchInput') as HTMLInputElement;
      input.value = q;
      doSearch(q);
    }
  });

function doSearch(q: string) {
  const query = q.trim().toLowerCase();
  const countEl = document.getElementById('resultCount')!;
  const container = document.getElementById('resultsContainer')!;
  const emptyState = document.getElementById('emptyState')!;

  if (!query) {
    container.innerHTML = '';
    countEl.textContent = '';
    emptyState.classList.remove('hidden');
    return;
  }

  emptyState.classList.add('hidden');

  // Split into words — all must match
  const words = query.split(/\s+/).filter(Boolean);

  const results = searchIndex.filter(ep => {
    const haystack = [ep.title, ep.description, ep.tag, ep.bodyText]
      .join(' ').toLowerCase();
    return words.every(w => haystack.includes(w));
  });

  // Sort — title matches first, then description, then body
  results.sort((a, b) => {
    const aTitle = a.title.toLowerCase().includes(query) ? 0 : 1;
    const bTitle = b.title.toLowerCase().includes(query) ? 0 : 1;
    return aTitle - bTitle;
  });

  countEl.textContent = results.length > 0
    ? `${results.length} result${results.length !== 1 ? 's' : ''} for "${q}"`
    : '';

  if (!results.length) {
    container.innerHTML = `
      <div class="no-results">
        <p>No episodes found for "${q}"</p>
        <span>Try a different keyword or browse a series</span>
      </div>`;
    return;
  }

  container.innerHTML = results.map(ep => `
    <a href="/${ep.series}/${ep.slug}/" class="result-card">
      <div class="result-card-top">
        <span class="result-series">${SERIES_LABELS[ep.series] ?? ep.series}</span>
        ${ep.tag ? `<span class="result-tag">${ep.tag}</span>` : ''}
      </div>
      <div class="result-title">${highlight(ep.title, words)}</div>
      <div class="result-desc">${ep.description}</div>
      <span class="result-arrow">→</span>
    </a>
  `).join('');
}

// Highlight matching words in title
function highlight(text: string, words: string[]): string {
  let result = text;
  words.forEach(word => {
    const re = new RegExp(`(${word})`, 'gi');
    result = result.replace(re, '<mark style="background:rgba(200,151,58,0.25);color:#f0e8d8;border-radius:2px;padding:0 2px;">$1</mark>');
  });
  return result;
}

// Debounced input handler
document.getElementById('searchInput')?.addEventListener('input', e => {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => {
    doSearch((e.target as HTMLInputElement).value);
  }, 150);
});
</script>

</Base>
