---
// Geo detection via browser navigator.language — no server needed
---

<div class="translate-banner" id="translateBanner" style="display:none">
  <div class="translate-banner-inner">
    <span class="translate-icon">🌐</span>
    <p class="translate-text">
      This page is in English.
      <span class="translate-lang" id="translateLang"></span>
    </p>
    <div class="translate-actions">
      <a
        href="#"
        class="translate-btn translate-btn-primary"
        id="translateBtn"
        target="_blank"
        rel="noopener noreferrer"
      >Translate page</a>
      <button class="translate-btn translate-btn-dismiss" id="translateDismiss">
        No thanks
      </button>
    </div>
  </div>
</div>

<style>
.translate-banner {
  position: fixed;
  bottom: 1.5rem; left: 50%;
  transform: translateX(-50%);
  z-index: 500;
  width: calc(100% - 3rem);
  max-width: 540px;
  background: rgba(20,18,24,0.97);
  border: 1px solid rgba(200,151,58,0.2);
  border-radius: 10px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  opacity: 0;
  transform: translateX(-50%) translateY(16px);
  transition: opacity 0.35s ease, transform 0.35s ease;
}
.translate-banner.visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.translate-banner-inner {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 1rem 1.25rem; flex-wrap: wrap;
}
.translate-icon { font-size: 1.1rem; flex-shrink: 0; }
.translate-text {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.65rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: #9a8f7e;
  flex: 1; min-width: 140px;
}
.translate-lang {
  color: #c8973a; display: block; margin-top: 0.15rem;
}
.translate-actions {
  display: flex; gap: 0.6rem; align-items: center; flex-shrink: 0;
}
.translate-btn {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.6rem; letter-spacing: 0.18em;
  text-transform: uppercase; cursor: pointer;
  border-radius: 4px; transition: all 0.2s;
  text-decoration: none; padding: 0.5rem 1rem;
  white-space: nowrap;
}
.translate-btn-primary {
  background: #8b3a1a; color: #f0e8d8;
  border: 1px solid #8b3a1a;
}
.translate-btn-primary:hover { background: #c4622a; border-color: #c4622a; }
.translate-btn-dismiss {
  background: none; color: #564b3c;
  border: 1px solid rgba(160,144,120,0.2);
}
.translate-btn-dismiss:hover { color: #9a8f7e; border-color: rgba(160,144,120,0.4); }

@media (max-width: 480px) {
  .translate-banner { bottom: 1rem; width: calc(100% - 2rem); }
  .translate-banner-inner { padding: 0.9rem 1rem; }
}
</style>

<script>
// Map browser language codes to Google Translate target codes + display names
const LANG_MAP: Record<string, { code: string; name: string }> = {
  af:{ code:'af', name:'Afrikaans' },
  ar:{ code:'ar', name:'Arabic' },
  az:{ code:'az', name:'Azerbaijani' },
  be:{ code:'be', name:'Belarusian' },
  bg:{ code:'bg', name:'Bulgarian' },
  bn:{ code:'bn', name:'Bengali' },
  bs:{ code:'bs', name:'Bosnian' },
  ca:{ code:'ca', name:'Catalan' },
  cs:{ code:'cs', name:'Czech' },
  cy:{ code:'cy', name:'Welsh' },
  da:{ code:'da', name:'Danish' },
  de:{ code:'de', name:'German' },
  el:{ code:'el', name:'Greek' },
  es:{ code:'es', name:'Spanish' },
  et:{ code:'et', name:'Estonian' },
  eu:{ code:'eu', name:'Basque' },
  fa:{ code:'fa', name:'Persian' },
  fi:{ code:'fi', name:'Finnish' },
  fr:{ code:'fr', name:'French' },
  gl:{ code:'gl', name:'Galician' },
  gu:{ code:'gu', name:'Gujarati' },
  he:{ code:'iw', name:'Hebrew' },
  hi:{ code:'hi', name:'Hindi' },
  hr:{ code:'hr', name:'Croatian' },
  hu:{ code:'hu', name:'Hungarian' },
  hy:{ code:'hy', name:'Armenian' },
  id:{ code:'id', name:'Indonesian' },
  is:{ code:'is', name:'Icelandic' },
  it:{ code:'it', name:'Italian' },
  ja:{ code:'ja', name:'Japanese' },
  ka:{ code:'ka', name:'Georgian' },
  kk:{ code:'kk', name:'Kazakh' },
  km:{ code:'km', name:'Khmer' },
  ko:{ code:'ko', name:'Korean' },
  lt:{ code:'lt', name:'Lithuanian' },
  lv:{ code:'lv', name:'Latvian' },
  mk:{ code:'mk', name:'Macedonian' },
  ml:{ code:'ml', name:'Malayalam' },
  mn:{ code:'mn', name:'Mongolian' },
  mr:{ code:'mr', name:'Marathi' },
  ms:{ code:'ms', name:'Malay' },
  my:{ code:'my', name:'Burmese' },
  ne:{ code:'ne', name:'Nepali' },
  nl:{ code:'nl', name:'Dutch' },
  no:{ code:'no', name:'Norwegian' },
  pa:{ code:'pa', name:'Punjabi' },
  pl:{ code:'pl', name:'Polish' },
  pt:{ code:'pt', name:'Portuguese' },
  ro:{ code:'ro', name:'Romanian' },
  ru:{ code:'ru', name:'Russian' },
  si:{ code:'si', name:'Sinhala' },
  sk:{ code:'sk', name:'Slovak' },
  sl:{ code:'sl', name:'Slovenian' },
  sq:{ code:'sq', name:'Albanian' },
  sr:{ code:'sr', name:'Serbian' },
  sv:{ code:'sv', name:'Swedish' },
  sw:{ code:'sw', name:'Swahili' },
  ta:{ code:'ta', name:'Tamil' },
  te:{ code:'te', name:'Telugu' },
  th:{ code:'th', name:'Thai' },
  tl:{ code:'tl', name:'Filipino' },
  tr:{ code:'tr', name:'Turkish' },
  uk:{ code:'uk', name:'Ukrainian' },
  ur:{ code:'ur', name:'Urdu' },
  uz:{ code:'uz', name:'Uzbek' },
  vi:{ code:'vi', name:'Vietnamese' },
  zh:{ code:'zh-CN', name:'Chinese' },
};

const DISMISSED_KEY = 'translate-dismissed';

function init() {
  // Dismissed for this session
  if (sessionStorage.getItem(DISMISSED_KEY)) return;

  // Get browser language (e.g. "fr-FR", "de", "zh-TW")
  const browserLang = (navigator.language || navigator.languages?.[0] || '').toLowerCase();
  const langBase = browserLang.split('-')[0]; // "fr-FR" → "fr"

  // Skip English speakers
  if (!langBase || langBase === 'en') return;

  const lang = LANG_MAP[langBase];
  if (!lang) return;

  const banner = document.getElementById('translateBanner');
  const langEl = document.getElementById('translateLang');
  const translateBtn = document.getElementById('translateBtn') as HTMLAnchorElement;
  const dismissBtn = document.getElementById('translateDismiss');

  if (!banner || !langEl || !translateBtn) return;

  langEl.textContent = `Translate to ${lang.name}?`;

  const pageUrl = encodeURIComponent(window.location.href);
  translateBtn.href = `https://translate.google.com/translate?sl=en&tl=${lang.code}&u=${pageUrl}`;

  // Show with slight delay so it doesn't feel instant/jarring
  banner.style.display = 'block';
  setTimeout(() => {
    requestAnimationFrame(() => banner.classList.add('visible'));
  }, 2000);

  dismissBtn?.addEventListener('click', () => {
    banner.classList.remove('visible');
    setTimeout(() => { banner.style.display = 'none'; }, 350);
    sessionStorage.setItem(DISMISSED_KEY, '1');
  });

  translateBtn.addEventListener('click', () => {
    sessionStorage.setItem(DISMISSED_KEY, '1');
  });
}

if (document.readyState === 'complete') init();
else window.addEventListener('load', init);
</script>
