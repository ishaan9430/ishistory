---
---

<div class="listen-wrap" id="listenWrap">
  <button class="listen-btn" id="listenBtn" aria-label="Listen to this article">
    <span class="listen-icon" id="listenIcon">
      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </span>
    <span class="listen-label" id="listenLabel">Listen to article</span>
  </button>

  <div class="listen-controls" id="listenControls" style="display:none">
    <button class="listen-ctrl" id="listenPause" aria-label="Pause">
      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
      </svg>
    </button>
    <button class="listen-ctrl" id="listenStop" aria-label="Stop">
      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
        <path d="M6 6h12v12H6z"/>
      </svg>
    </button>
    <div class="listen-progress-wrap">
      <div class="listen-progress-bar" id="listenProgressBar"></div>
    </div>
    <span class="listen-time" id="listenTime">0%</span>
  </div>
</div>

<style>
.listen-wrap {
  display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
}
.listen-btn {
  display: inline-flex; align-items: center; gap: 0.55rem;
  padding: 0.65rem 1.3rem;
  background: none;
  border: 1px solid rgba(200,151,58,0.32);
  color: #9a8f7e; cursor: pointer;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.62rem; letter-spacing: 0.13em;
  text-transform: uppercase;
  transition: all 0.2s; border-radius: 3px;
}
.listen-btn:hover { border-color: #c8973a; color: #c8973a; }
.listen-btn.active { border-color: #c8973a; color: #c8973a; background: rgba(200,151,58,0.06); }
.listen-icon { display: flex; align-items: center; flex-shrink: 0; }

.listen-controls {
  display: flex; align-items: center; gap: 0.6rem;
  flex: 1; min-width: 180px;
}
.listen-ctrl {
  display: flex; align-items: center; justify-content: center;
  width: 28px; height: 28px;
  background: rgba(200,151,58,0.08);
  border: 1px solid rgba(200,151,58,0.2);
  border-radius: 50%; cursor: pointer;
  color: #9a8f7e; transition: all 0.2s; flex-shrink: 0;
}
.listen-ctrl:hover { background: rgba(200,151,58,0.16); color: #c8973a; }
.listen-progress-wrap {
  flex: 1; height: 2px;
  background: rgba(200,151,58,0.12);
  border-radius: 2px; overflow: hidden;
}
.listen-progress-bar {
  height: 100%; width: 0%;
  background: linear-gradient(to right, #8b3a1a, #c8973a);
  border-radius: 2px; transition: width 0.5s linear;
}
.listen-time {
  font-family: 'DM Mono', monospace;
  font-size: 0.55rem; letter-spacing: 0.1em;
  color: #564b3c; flex-shrink: 0; min-width: 28px; text-align: right;
}
.listen-unsupported {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.58rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: #564b3c;
}
</style>

<script>
const btn = document.getElementById('listenBtn') as HTMLButtonElement;
const label = document.getElementById('listenLabel')!;
const icon = document.getElementById('listenIcon')!;
const controls = document.getElementById('listenControls')!;
const pauseBtn = document.getElementById('listenPause')!;
const stopBtn = document.getElementById('listenStop')!;
const progressBar = document.getElementById('listenProgressBar')!;
const timeEl = document.getElementById('listenTime')!;
const wrap = document.getElementById('listenWrap')!;

if (!('speechSynthesis' in window)) {
  wrap.innerHTML = '<span class="listen-unsupported">Audio not supported in this browser</span>';
} else {
  const synth = window.speechSynthesis;
  let utterance: SpeechSynthesisUtterance | null = null;
  let isPaused = false;
  let totalLength = 0;

  const PAUSE_SVG = `<svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>`;
  const PLAY_SVG  = `<svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M8 5v14l11-7z"/></svg>`;
  const PAUSE_CTRL_SVG = `<svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>`;
  const PLAY_CTRL_SVG  = `<svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M8 5v14l11-7z"/></svg>`;

  function getArticleText(): string {
    const article = document.querySelector('.ep-article');
    if (!article) return '';
    const clone = article.cloneNode(true) as HTMLElement;
    clone.querySelectorAll('.ep-toc-wrap, script, style').forEach(el => el.remove());
    return (clone.textContent ?? '').replace(/\s+/g, ' ').trim();
  }

  function setProgress(index: number, total: number) {
    const pct = total > 0 ? Math.round((index / total) * 100) : 0;
    progressBar.style.width = pct + '%';
    timeEl.textContent = pct + '%';
  }

  function resetUI() {
    btn.classList.remove('active');
    label.textContent = 'Listen to article';
    icon.innerHTML = PLAY_SVG;
    controls.style.display = 'none';
    pauseBtn.innerHTML = PAUSE_CTRL_SVG;
    progressBar.style.width = '0%';
    timeEl.textContent = '0%';
    isPaused = false;
    utterance = null;
  }

  // Load voices — critical fix for mobile Chrome
  // Voices load asynchronously; we must wait for them
  function getVoices(): Promise<SpeechSynthesisVoice[]> {
    return new Promise(resolve => {
      const voices = synth.getVoices();
      if (voices.length > 0) { resolve(voices); return; }
      // Not loaded yet — wait for event
      synth.addEventListener('voiceschanged', () => resolve(synth.getVoices()), { once: true });
      // Fallback timeout in case event never fires
      setTimeout(() => resolve(synth.getVoices()), 1000);
    });
  }

  function pickVoice(voices: SpeechSynthesisVoice[]): SpeechSynthesisVoice | null {
    // Prefer high-quality English voices by name
    const preferred = ['Daniel', 'Karen', 'Samantha', 'Google UK English Male',
                       'Google UK English Female', 'Microsoft David', 'Microsoft Zira'];
    for (const name of preferred) {
      const v = voices.find(v => v.name.includes(name));
      if (v) return v;
    }
    // Fall back to any English voice
    return voices.find(v => v.lang.startsWith('en')) ?? voices[0] ?? null;
  }

  btn.addEventListener('click', async () => {
    // Resume if paused
    if (isPaused) {
      synth.resume();
      isPaused = false;
      btn.classList.add('active');
      label.textContent = 'Listening…';
      icon.innerHTML = PAUSE_SVG;
      pauseBtn.innerHTML = PAUSE_CTRL_SVG;
      return;
    }

    // Already speaking — ignore double click
    if (synth.speaking) return;

    const text = getArticleText();
    if (!text) { label.textContent = 'No content found'; return; }

    totalLength = text.length;

    // Show loading state
    btn.classList.add('active');
    label.textContent = 'Loading voice…';

    // Cancel any existing speech
    synth.cancel();

    // Wait for voices to be ready
    const voices = await getVoices();
    const voice = pickVoice(voices);

    utterance = new SpeechSynthesisUtterance(text);
    utterance.rate = 0.92;
    utterance.pitch = 1;
    utterance.lang = 'en-GB';
    if (voice) utterance.voice = voice;

    utterance.onstart = () => {
      label.textContent = 'Listening…';
      icon.innerHTML = PAUSE_SVG;
      controls.style.display = 'flex';
    };

    utterance.onboundary = (e) => {
      setProgress(e.charIndex, totalLength);
    };

    utterance.onend = () => resetUI();
    utterance.onerror = (e) => {
      // 'interrupted' fires when we cancel intentionally — ignore
      if (e.error === 'interrupted' || e.error === 'canceled') return;
      resetUI();
      label.textContent = 'Listen to article';
    };

    synth.speak(utterance);
  });

  // Pause / resume
  pauseBtn.addEventListener('click', () => {
    if (synth.speaking && !isPaused) {
      synth.pause();
      isPaused = true;
      btn.classList.remove('active');
      label.textContent = 'Paused';
      icon.innerHTML = PLAY_SVG;
      pauseBtn.innerHTML = PLAY_CTRL_SVG;
    } else if (isPaused) {
      synth.resume();
      isPaused = false;
      btn.classList.add('active');
      label.textContent = 'Listening…';
      icon.innerHTML = PAUSE_SVG;
      pauseBtn.innerHTML = PAUSE_CTRL_SVG;
    }
  });

  // Stop
  stopBtn.addEventListener('click', () => { synth.cancel(); resetUI(); });

  // Stop on navigation
  window.addEventListener('beforeunload', () => synth.cancel());

  // Fix for Chrome bug — speech stops after ~15 seconds without this
  setInterval(() => {
    if (synth.speaking && !isPaused) {
      synth.pause();
      synth.resume();
    }
  }, 10000);
}
</script>
