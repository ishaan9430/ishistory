---
interface Props {
  slug: string;
  series: string;
}
const { slug, series } = Astro.props;
const episodeSlug = `${series}/${slug}`;
---

<div class="comments-wrap" id="commentsWrap">
  <div class="comments-header">
    <h2 class="comments-title">Discussion</h2>
    <span class="comments-count" id="commentsCount"></span>
  </div>

  <!-- Comment list -->
  <div class="comments-list" id="commentsList">
    <div class="comments-loading" id="commentsLoading">
      <div class="comments-spinner"></div>
    </div>
  </div>

  <div class="comments-empty" id="commentsEmpty" style="display:none">
    <p>No comments yet. Be the first to share your thoughts.</p>
  </div>

  <!-- Comment form -->
  <div class="comment-form-wrap">
    <h3 class="comment-form-title">Leave a comment</h3>
    <form class="comment-form" id="commentForm">
      <div class="comment-form-row">
        <div class="comment-field">
          <label class="comment-label" for="commentName">Name</label>
          <input
            type="text"
            id="commentName"
            class="comment-input"
            placeholder="Your name"
            maxlength="60"
            required
          />
        </div>
      </div>
      <div class="comment-field">
        <label class="comment-label" for="commentMessage">Comment</label>
        <textarea
          id="commentMessage"
          class="comment-textarea"
          placeholder="Share your thoughts on this episode…"
          maxlength="1000"
          rows="4"
          required
        ></textarea>
        <div class="comment-char-count">
          <span id="commentCharCount">0</span>/1000
        </div>
      </div>
      <div class="comment-form-footer">
        <button type="submit" class="comment-submit-btn" id="commentSubmitBtn">
          <span id="commentBtnText">Post Comment</span>
          <span id="commentBtnLoader" style="display:none">Posting…</span>
        </button>
        <p class="comment-error" id="commentError" style="display:none"></p>
      </div>
    </form>
    <div class="comment-success" id="commentSuccess" style="display:none">
      <span class="comment-success-icon">✓</span>
      <p>Comment posted! Thank you for sharing your thoughts.</p>
    </div>
  </div>
</div>

<style>
.comments-wrap {
  background: #0d0b10;
  border-top: 1px solid rgba(200,151,58,0.09);
  padding: 3rem;
  position: relative; z-index: 1;
}
.comments-header {
  display: flex; align-items: center; gap: 1rem;
  margin-bottom: 2rem;
}
.comments-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.4rem; font-weight: 700;
  font-style: italic; color: #f0e8d8;
}
.comments-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem; letter-spacing: 0.1em;
  color: #564b3c;
  background: rgba(200,151,58,0.07);
  padding: 0.2rem 0.6rem; border-radius: 20px;
}

/* Loading */
.comments-loading {
  display: flex; justify-content: center; padding: 2rem;
}
.comments-spinner {
  width: 20px; height: 20px; border-radius: 50%;
  border: 2px solid rgba(200,151,58,0.15);
  border-top-color: #c8973a;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Empty state */
.comments-empty {
  text-align: center; padding: 2rem 0;
  font-family: 'Crimson Pro', serif;
  font-size: 1rem; font-style: italic; color: #564b3c;
}

/* Comment cards */
.comment-card {
  display: flex; gap: 1rem;
  padding: 1.4rem 0;
  border-bottom: 1px solid rgba(200,151,58,0.07);
}
.comment-card:last-child { border-bottom: none; }
.comment-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(200,151,58,0.12);
  border: 1px solid rgba(200,151,58,0.2);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Libre Baskerville', serif;
  font-size: 0.85rem; font-weight: 700;
  color: #c8973a; flex-shrink: 0;
  text-transform: uppercase;
}
.comment-body { flex: 1; min-width: 0; }
.comment-meta {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 0.5rem; flex-wrap: wrap;
}
.comment-name {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.65rem; letter-spacing: 0.15em;
  text-transform: uppercase; color: #cfc3ab;
  font-weight: 600;
}
.comment-date {
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem; letter-spacing: 0.08em;
  color: #3a3028;
}
.comment-text {
  font-family: 'Crimson Pro', serif;
  font-size: 1rem; line-height: 1.75;
  color: #9a8f7e;
}

/* Form */
.comment-form-wrap {
  margin-top: 3rem;
  padding-top: 2.5rem;
  border-top: 1px solid rgba(200,151,58,0.09);
}
.comment-form-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.1rem; font-weight: 700;
  font-style: italic; color: #f0e8d8;
  margin-bottom: 1.5rem;
}
.comment-form-row {
  display: grid; grid-template-columns: 1fr;
  gap: 1rem; margin-bottom: 1rem;
}
.comment-field { display: flex; flex-direction: column; gap: 0.4rem; }
.comment-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.58rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: #564b3c;
}
.comment-input,
.comment-textarea {
  background: rgba(20,18,24,0.8);
  border: 1px solid rgba(160,144,120,0.15);
  border-radius: 4px;
  color: #e4d9c4;
  font-family: 'Crimson Pro', serif; font-size: 1rem;
  padding: 0.8rem 1rem; outline: none;
  transition: border-color 0.2s;
  resize: vertical;
}
.comment-input:focus,
.comment-textarea:focus {
  border-color: rgba(200,151,58,0.38);
}
.comment-input::placeholder,
.comment-textarea::placeholder { color: #3a3028; font-style: italic; }
.comment-char-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.55rem; letter-spacing: 0.08em;
  color: #3a3028; text-align: right;
  margin-top: 0.25rem;
}
.comment-form-footer {
  display: flex; align-items: center; gap: 1rem;
  flex-wrap: wrap; margin-top: 1rem;
}
.comment-submit-btn {
  padding: 0.8rem 1.8rem;
  background: #8b3a1a; color: #f0e8d8;
  border: none; border-radius: 3px; cursor: pointer;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.62rem; letter-spacing: 0.18em;
  text-transform: uppercase;
  transition: background 0.2s;
}
.comment-submit-btn:hover { background: #c4622a; }
.comment-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.comment-error {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 0.58rem; letter-spacing: 0.1em;
  text-transform: uppercase; color: #e06060;
}
.comment-success {
  display: flex; align-items: flex-start; gap: 0.75rem;
  padding: 1.2rem; margin-top: 1rem;
  background: rgba(90,160,90,0.08);
  border: 1px solid rgba(90,160,90,0.2);
  border-radius: 6px;
}
.comment-success-icon { color: #5a9; font-size: 1.1rem; }
.comment-success p {
  font-family: 'Crimson Pro', serif;
  font-size: 1rem; font-style: italic; color: #9a8f7e;
}

@media (max-width: 768px) {
  .comments-wrap { padding: 2rem 1.5rem; }
}
</style>

<script define:vars={{ episodeSlug }}>
const API = `/api/comments?slug=${encodeURIComponent(episodeSlug)}`;

function esc(str) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function formatDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function renderComments(comments) {
  const list = document.getElementById('commentsList');
  const empty = document.getElementById('commentsEmpty');
  const count = document.getElementById('commentsCount');
  const loading = document.getElementById('commentsLoading');

  if (loading) loading.style.display = 'none';

  if (!comments || comments.length === 0) {
    if (empty) empty.style.display = 'block';
    if (count) count.textContent = '0 comments';
    return;
  }

  if (count) count.textContent = `${comments.length} comment${comments.length !== 1 ? 's' : ''}`;

  list.innerHTML = comments.map(c => `
    <div class="comment-card">
      <div class="comment-avatar">${esc(c.name.charAt(0))}</div>
      <div class="comment-body">
        <div class="comment-meta">
          <span class="comment-name">${esc(c.name)}</span>
          <span class="comment-date">${formatDate(c.created_at)}</span>
        </div>
        <p class="comment-text">${esc(c.message)}</p>
      </div>
    </div>
  `).join('');
}

// Load comments
async function loadComments() {
  try {
    const res = await fetch(API);
    if (res.ok) {
      const comments = await res.json();
      renderComments(comments);
    }
  } catch {
    const loading = document.getElementById('commentsLoading');
    if (loading) loading.style.display = 'none';
  }
}

loadComments();

// Character counter
const messageEl = document.getElementById('commentMessage');
const charCount = document.getElementById('commentCharCount');
messageEl?.addEventListener('input', () => {
  if (charCount) charCount.textContent = messageEl.value.length;
});

// Submit form
const form = document.getElementById('commentForm');
const submitBtn = document.getElementById('commentSubmitBtn');
const btnText = document.getElementById('commentBtnText');
const btnLoader = document.getElementById('commentBtnLoader');
const errorEl = document.getElementById('commentError');
const successEl = document.getElementById('commentSuccess');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const name = document.getElementById('commentName').value.trim();
  const message = messageEl.value.trim();

  if (!name || !message) return;

  submitBtn.disabled = true;
  btnText.style.display = 'none';
  btnLoader.style.display = 'inline';
  errorEl.style.display = 'none';

  try {
    const res = await fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, message })
    });
    const data = await res.json();

    if (data.success) {
      form.style.display = 'none';
      successEl.style.display = 'flex';
      await loadComments();
    } else {
      errorEl.textContent = data.error ?? 'Something went wrong.';
      errorEl.style.display = 'block';
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoader.style.display = 'none';
    }
  } catch {
    errorEl.textContent = 'Network error. Please try again.';
    errorEl.style.display = 'block';
    submitBtn.disabled = false;
    btnText.style.display = 'inline';
    btnLoader.style.display = 'none';
  }
});
</script>
